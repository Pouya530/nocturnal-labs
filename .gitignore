# Dependencies & build output
node_modules
.next
.next-dev
out
*.log

# Environment & secrets (never commit real credentials)
.env
.env.*
!.env.example
.envrc
.local.env

# Sensitive / crypto material
*.pem
*.p12
*.key
*.crt
*.cer
*.pfx
*.keystore
id_rsa
id_rsa.pub
*.secret
secrets/

# Cloud / CI secrets often dropped locally
*credentials*.json
*-credentials.json
*-service-account*.json
.vercel

# OS / editor noise
.DS_Store
Thumbs.db

# Archives & dumps (avoid accidental uploads like Archive.zip)
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# Markdown: ignore stray/internal docs; allow root README for GitHub if you add one later
*.md
!README.md

# Other documents you typically do not want in the repo
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx

# TypeScript incremental cache
*.tsbuildinfo

# Working copies of brand assets in repo root (canonical files: public/brand/)
/*.png
