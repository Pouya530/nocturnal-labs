{
  "name": "nocturnal-labs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DEV=1 next dev",
    "dev:clean": "node -e \"const fs=require('fs');for(const d of ['.next','.next-dev']){try{fs.rmSync(d,{recursive:true,force:true});}catch(e){if(e&&e.code!=='ENOENT')throw e;}}\"",
    "dev:fresh": "npm run dev:clean && NEXT_DIST_DEV=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "9.114.3",
    "@react-three/fiber": "8.17.10",
    "detect-gpu": "^5.0.70",
    "next": "^14.2.28",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "0.170.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@types/three": "0.170.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.28",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
