# Canonical URL for metadata, sitemap, and JSON-LD (no trailing slash).
# In production, set this to your public domain so previews are not used as canonical.
#
# Local dev: leave unset — `getSiteUrl()` falls back to http://localhost:3000 (see src/lib/site.ts).
# Use when Next listens on another host/port (or for explicit localhost canonicals / OG checks):
# NEXT_PUBLIC_DEV_SITE_URL=http://localhost:3001
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 measurement ID (public). Omit to disable gtag on the build.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
